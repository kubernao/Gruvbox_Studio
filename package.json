{
  "name": "gruvbox studio",
  "productName": "Gruvbox Studio",
  "version": "1.0.0",
  "description": "My Electron application description",
  "main": ".webpack/main",
  "private": true,
  "scripts": {
    "start": "electron-forge start",
    "build:prepare": "npm run build:pi && npm run build:rust",
    "build:mac-icon": "bash scripts/sync-brand-icons-from-composer.sh",
    "build:from-source": "npm run build:prepare && npm run build:prod",
    "prepackage": "npm run build:prepare && npm run build:mac-icon",
    "premake": "npm run build:prepare && npm run build:mac-icon",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "release:desktop": "bash scripts/build-production-package.sh",
    "publish": "electron-forge publish",
    "lint": "npm run typecheck && npm run lint:bridge",
    "lint:styles": "stylelint \"src/frontend/**/*.css\"",
    "lint:bridge": "node tests/verify-ipc-bridge.js",
    "lint:generated": "node scripts/verify-generated-artifacts.cjs",
    "lint:pi": "npm --prefix \"submodules/pi-mono\" run check",
    "typecheck": "tsc --noEmit",
    "test:e2e:preflight": "node scripts/ensure-e2e-package.cjs",
    "test": "node scripts/ensure-e2e-package.cjs && playwright test",
    "test:headed": "node scripts/ensure-e2e-package.cjs && playwright test --headed",
    "test:e2e:smoke": "node scripts/ensure-e2e-package.cjs && playwright test tests/e2e/app-loading.test.ts tests/e2e/mdx-markdown-smoke.test.ts tests/e2e/editor-file-loading.test.ts tests/e2e/git-history-workflows.test.ts tests/e2e/editor-document-persistence.test.ts",
    "test:visual": "node scripts/ensure-e2e-package.cjs && playwright test tests/e2e/visual-critical-ui.test.ts",
    "test:ux": "node scripts/ensure-e2e-package.cjs && playwright test tests/e2e/ux-signals.test.ts",
    "test:scenario-backlog": "node --test tests/unit/e2e-scenario-backlog.test.cjs",
    "pw:planner": "node scripts/run-playwright-agent.cjs --role planner",
    "pw:generator": "node scripts/run-playwright-agent.cjs --role generator",
    "pw:healer": "node scripts/run-playwright-agent.cjs --role healer",
    "test:unit": "node --test \"tests/unit/*.test.cjs\"",
    "test:vitest": "vitest run",
    "qa:fast": "npm run typecheck && npm run lint:bridge && npm run lint:generated && npm run test:unit",
    "qa:smoke": "npm run test:smoke && npm run test:e2e:smoke && npm run lint:pi",
    "qa:full": "npm run quality:ci && npm test",
    "qa:agent": "node scripts/run-agent-qa.cjs --tier=fast",
    "qa:diagnose:fast": "node scripts/run-agent-qa.cjs --tier=fast --continue-on-fail --out .cursor/reports/qa-diagnose-fast.json",
    "qa:diagnose:smoke": "node scripts/run-agent-qa.cjs --tier=smoke --continue-on-fail --out .cursor/reports/qa-diagnose-smoke.json",
    "test:all": "npm run lint && npm run test:unit && npm run test:vitest && npm run test",
    "test:smoke": "npm run lint && npm run test:unit && npm run lint:bridge",
    "quality:ci": "npm run lint && npm run lint:generated && npm run test:unit && npm run test:vitest && npm run lint:pi",
    "build:analyze": "cross-env WEBPACK_ANALYZE=1 electron-forge package",
    "build:prod": "cross-env NODE_ENV=production electron-forge package",
    "build:prod:no-console": "cross-env NODE_ENV=production STRIP_CONSOLE=1 electron-forge package",
    "e2e:mine-scenarios": "node scripts/generate-e2e-scenario-backlog.cjs",
    "build:rust:addon": "node scripts/build-rust-sidecar.cjs",
    "build:rust": "npm run build:rust:addon",
    "build:pi": "npm --prefix \"submodules/pi-mono\" install && npm --prefix \"submodules/pi-mono\" run build"
  },
  "keywords": [],
  "author": "Gruvbox Studio Contributors",
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-webpack": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/diff-match-patch": "^1.0.36",
    "@vercel/webpack-asset-relocator-loader": "^1.7.3",
    "@vitest/coverage-v8": "^4.1.4",
    "compression-webpack-plugin": "^12.0.0",
    "cross-env": "^10.1.0",
    "css-loader": "^6.11.0",
    "css-minimizer-webpack-plugin": "^8.0.0",
    "electron": "41.2.1",
    "happy-dom": "^20.9.0",
    "image-minimizer-webpack-plugin": "^5.0.0",
    "imagemin": "^9.0.1",
    "imagemin-mozjpeg": "^10.0.0",
    "imagemin-pngquant": "^10.0.0",
    "imagemin-svgo": "^12.0.0",
    "jsdom": "^29.0.2",
    "monaco-editor-webpack-plugin": "^7.1.1",
    "node-loader": "^2.1.0",
    "playwright": "^1.59.1",
    "style-loader": "^3.3.4",
    "stylelint": "^17.9.1",
    "stylelint-config-standard": "^40.0.0",
    "terser-webpack-plugin": "^5.5.0",
    "ts-loader": "^9.5.7",
    "vitest": "^4.1.4",
    "webpack-bundle-analyzer": "^5.3.0"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@codemirror/autocomplete": "^6.14.0",
    "@codemirror/commands": "^6.4.0",
    "@codemirror/lang-javascript": "^6.2.2",
    "@codemirror/lang-json": "^6.0.1",
    "@codemirror/lang-markdown": "^6.2.5",
    "@codemirror/language": "^6.10.1",
    "@codemirror/search": "^6.5.4",
    "@codemirror/state": "^6.4.1",
    "@codemirror/view": "^6.26.2",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.1",
    "@markwhen/codemirror-tables": "^0.1.1",
    "@mdxeditor/editor": "^3.54.1",
    "@svar-ui/react-core": "^2.5.0",
    "@svar-ui/react-toolbar": "^2.5.0",
    "@types/katex": "^0.16.8",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "codemirror": "^6.0.2",
    "codemirror-lang-latex": "^0.3.0",
    "codemirror-lang-mermaid": "^0.5.0",
    "commit-graph": "^2.4.0",
    "dictionary-en": "^4.0.0",
    "diff-match-patch": "^1.0.5",
    "dompurify": "^3.4.1",
    "electron-squirrel-startup": "^1.0.1",
    "fuzzysort": "^3.1.0",
    "html-to-docx": "^1.8.0",
    "katex": "^0.16.45",
    "keytar": "^7.9.0",
    "lucide-react": "^1.8.0",
    "marked": "^18.0.2",
    "mermaid": "^11.14.0",
    "monaco-editor": "^0.55.1",
    "nspell": "^2.1.5",
    "path-browserify": "^1.0.1",
    "pdfjs-dist": "^5.7.284",
    "react": "^19.2.5",
    "react-complex-tree": "^2.6.1",
    "react-dom": "^19.2.5",
    "react-resizable-panels": "^4.10.0",
    "text-readability": "^1.1.1",
    "typescript": "^6.0.3",
    "write-good": "^1.0.8"
  }
}
