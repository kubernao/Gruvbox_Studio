# Optional dev overrides (Gruvie settings UI is the usual path for keys)

# Required for chat (OpenRouter)
OPENROUTER_API_KEY=

# Optional: cloud TTS / audiobook (OpenAI speech API)
OPENAI_API_KEY=

# Optional: Gruvie web_search tool
GRUVBOX_BRAVE_SEARCH_API_KEY=
BRAVE_API_KEY=

# Debug
GRUVBOX_PI_DEBUG=0
